<?xml version="1.0"?>
<phpunit
  bootstrap="tests/bootstrap.php"
  colors="true"
  verbose="true"
  backupGlobals="false"
>
  <testsuites>
    <testsuite name="llms-md">
      <directory suffix=".php">tests</directory>
    </testsuite>
  </testsuites>
  <php>
    <env name="WP_PHPUNIT__TESTS_CONFIG" value="tests/wp-tests-config.php"/>
  </php>
</phpunit>
